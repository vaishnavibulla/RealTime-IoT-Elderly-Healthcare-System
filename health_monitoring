#include <Wire.h>
#include <LiquidCrystal_I2C.h>
LiquidCrystal_I2C lcd(0x27, 16, 2);

#include <RTClib.h>
RTC_DS3231 rtc;

#define USE_ARDUINO_INTERRUPTS true  // Set-up low-level interrupts for most acurate BPM math
#include <PulseSensorPlayground.h>   // Includes the PulseSensorPlayground Library

#include <Adafruit_MLX90614.h>
Adafruit_MLX90614 mlx = Adafruit_MLX90614();

const int PulseWire = A0;           // 'S' Signal pin connected to A0
const int LED13 = 13;               // The on-board Arduino LED
int Threshold = 550;                // Determine which Signal to "count as a beat" and which to ignore
PulseSensorPlayground pulseSensor;  // Creates an object

const int ECGPin = A1;
const int LOPlus = 9;
const int LOMinus = 8;
#define buzzer (11)

int led1 = 7;
int led2 = 6;
int led3 = 5;
int led4 = 4;

String msg = "INTELLIGENT IOT ARCHITECTURE FOR CONTINOUS ELDERLY HEALTH SURVRILLANCE AND AUTOMATED MEDICATION DEVLIVERY";

void setup() {
  Serial.begin(9600);

  lcd.init();
  lcd.backlight();
  pinMode(buzzer, OUTPUT);
  pinMode(led1, OUTPUT);
  pinMode(led2, OUTPUT);
  pinMode(led3, OUTPUT);
  pinMode(led4, OUTPUT);
  // ----------- RUN SCROLL ONLY ONCE -----------
  for (int i = 0; i < msg.length() - 15; i++) {
    lcd.clear();
    lcd.setCursor(0, 1);
    lcd.print(msg.substring(i, i + 16));
    lcd.setCursor(0, 0);
    lcd.print("PROJECT TITLE");
    delay(500);
  }
  if (!rtc.begin()) {
    lcd.print("RTC Error");
    while (1)
      ;
  }

  // Upload once with this line enabled
  rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
  // Configure the PulseSensor object, by assigning our variables to it
  pulseSensor.analogInput(PulseWire);
  pulseSensor.blinkOnPulse(LED13);  // Blink on-board LED with heartbeat
  pulseSensor.setThreshold(Threshold);

  // Double-check the "pulseSensor" object was created and began seeing a signal
  if (pulseSensor.begin()) {
    Serial.println("PulseSensor object created!");
  }

  Serial.begin(9600);
  while (!Serial)
    ;

  if (!mlx.begin()) {
    Serial.println("Error connecting to MLX sensor. Check wiring.");
    while (1)
      ;
  };
  digitalWrite(buzzer, LOW);
  digitalWrite(led1, LOW);
  digitalWrite(led2, LOW);
  digitalWrite(led3, LOW);
  digitalWrite(led4, LOW);
}

void loop() {

  DateTime now = rtc.now();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Time:");
  if (now.hour() < 10) lcd.print("0");
  lcd.print(now.hour());
  lcd.print(":");
  if (now.minute() < 10) lcd.print("0");
  lcd.print(now.minute());
  lcd.print(":");
  if (now.second() < 10) lcd.print("0");
  lcd.print(now.second());
  lcd.setCursor(0, 1);
  lcd.print("Date:");
  if (now.day() < 10) lcd.print("0");
  lcd.print(now.day());
  lcd.print("/");
  if (now.month() < 10) lcd.print("0");
  lcd.print(now.month());
  lcd.print("/");
  lcd.print(now.year());
  delay(1000);
  int myBPM = pulseSensor.getBeatsPerMinute();  // Calculates BPM

  if (pulseSensor.sawStartOfBeat()) {            // Constantly test to see if a beat happened
    Serial.print("♥  A HeartBeat Happened ! ");  // If true, print a message
    Serial.print("BPM: ");
    Serial.print(myBPM);  // Print the BPM value
  }

  Serial.print("\tTemp = ");
  Serial.print(mlx.readObjectTempC());
  Serial.print("*C");

  if ((digitalRead(LOPlus) == HIGH) || (digitalRead(LOMinus) == HIGH)) {
    Serial.println("\tLeads Off!");
  } else {
    Serial.print("\t");
    Serial.println(analogRead(ECGPin));
  }

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("BPM:");
  lcd.setCursor(4, 0);
  lcd.print(myBPM);
  lcd.setCursor(0, 1);
  lcd.print("TEM:");
  lcd.setCursor(4, 1);
  lcd.print(mlx.readObjectTempC());
  lcd.setCursor(9, 0);
  lcd.print("CON:");
  lcd.setCursor(9, 1);
  lcd.print("CON:");
  delay(500);
  if (myBPM < 10 && myBPM > 59) {
    Serial.println("LOW BPM");
    digitalWrite(led1, HIGH);
    lcd.setCursor(13, 0);
    lcd.print("LOW");
    delay(500);
  }
  if (myBPM > 60 && myBPM < 120) {
    Serial.println("NOR BPM");
    digitalWrite(led1, LOW);
    lcd.setCursor(13, 0);
    lcd.print("NOR");
    delay(500);
  }
  if (myBPM > 120) {
    Serial.println("HIGH BPM");
    digitalWrite(led1, HIGH);
    lcd.setCursor(13, 0);
    lcd.print("HIGH");
    delay(500);
  }
  if (mlx.readObjectTempC() < 30) {
    digitalWrite(led2, HIGH);
    Serial.println("LOW TEMP");
    lcd.setCursor(13, 1);
    lcd.print("LOW");
    delay(500);
  }
  if (mlx.readObjectTempC() > 31 && mlx.readObjectTempC() < 45) {
    digitalWrite(led2, LOW);
    Serial.println("NOR TEMP");
    lcd.setCursor(13, 1);
    lcd.print("NOR");
    delay(500);
  }
  if (mlx.readObjectTempC() > 46) {
    digitalWrite(led2, HIGH);
    Serial.println("HIGH TEMP");
    lcd.setCursor(13, 1);
    lcd.print("HIGH");
    delay(500);
  }
  if ((now.minute() % 2 == 0) && (now.second() == 0)) {
    Serial.println("REMINDER FOR TABLET");
    digitalWrite(led3, HIGH);
    digitalWrite(led4, HIGH);
    digitalWrite(buzzer, HIGH);
    delay(1000);  // Beep for 1 second
    digitalWrite(buzzer, LOW);
    delay(1000);
    digitalWrite(buzzer, HIGH);
    delay(1000);  // Beep for 1 second
    digitalWrite(buzzer, LOW);
    delay(1000);
    digitalWrite(buzzer, HIGH);
    delay(1000);  // Beep for 1 second
    digitalWrite(buzzer, LOW);
    digitalWrite(led1, LOW);
    digitalWrite(led2, LOW);
    digitalWrite(led3, LOW);
    digitalWrite(led4, LOW);
    delay(1000);
  }
}
